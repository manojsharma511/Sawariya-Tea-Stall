rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the authenticated user is the admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token != null &&
             request.auth.token.email == 'manojkumarsharma27096@gmail.com';
    }

    // Testimonials: Logged-in users can write, public can read, admin can manage all
    match /testimonials/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Offers: Public read, Admin write
    match /offers/{id} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    // Site Content: Public read, Admin write
    match /site_content/{id} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    // User Profiles: Public read, owner write/update
    match /users/{userId} {
      allow read: if true;
      allow write, update: if request.auth != null && request.auth.uid == userId;
    }

    // Prices: Public read, Admin write
    match /prices/{id} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    // Gallery: Public read, Admin write
    match /gallery/{id} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    // Menu Items: Public read, Admin write
    match /menu_items/{id} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }
  }
}
